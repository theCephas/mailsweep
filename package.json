{
  "name": "mailsweep",
  "version": "1.0.0",
  "private": true,
  "description": "Clean your inbox. Reclaim your peace.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"yarn workspace @mailsweep/api dev\" \"yarn workspace @mailsweep/web dev\"",
    "build": "yarn workspaces foreach -A run build",
    "clean": "yarn workspaces foreach -A run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
